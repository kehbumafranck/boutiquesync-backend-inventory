# ============================================================
# Fichier d'exemple .env — copier vers .env et remplir les valeurs
# NE JAMAIS COMMITER le fichier .env réel !
# ============================================================

# Profil Spring
SPRING_PROFILES_ACTIVE=dev

# MongoDB
MONGODB_URI=mongodb://localhost:27017/boutiquesync

# JWT & Sécurité
# Générer avec: openssl rand -base64 32
JWT_SECRET=
# Clé AES 32 bytes pour chiffrement TOTP
# Générer avec: openssl rand -base64 24
TOTP_KEY=

# Mail (Gmail App Password recommandé)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# Boutique
SHOP_NAME=Ma Boutique
SHOP_ADDRESS=
SHOP_PHONE=
SHOP_EMAIL=
SHOP_VAT_NUMBER=

# Mail display
MAIL_FROM_NAME=BoutiqueSync

# Invitation
INVITATION_EXPIRY_HOURS=24

# Frontend
FRONTEND_BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
# URLs CORS supplémentaires (séparées par des virgules) :
FRONTEND_EXTRA_URLS=https://mondomaine.com

# Cookies (true en prod HTTPS, false en dev HTTP)
COOKIE_SECURE=${COOKIE_SECURE:true}
COOKIE_SAME_SITE=${COOKIE_SAME_SITE:Lax}

# WhatsApp (optionnel)
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ACCESS_TOKEN=
